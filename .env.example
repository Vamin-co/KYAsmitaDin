# Supabase — project URL and keys (new-style sb_publishable_ / sb_secret_ keys supported)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Secret — SERVER ONLY. Never expose in a NEXT_PUBLIC_ var or the client bundle.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Telegram bot token — SERVER ONLY.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Session signing secret (random long string) — SERVER ONLY.
SESSION_SECRET=change-me-to-a-long-random-string

# Deployed app URL — used by the bot's Mini App launch button + setWebhook script.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Optional shared secret to authenticate the Telegram webhook — SERVER ONLY.
TELEGRAM_WEBHOOK_SECRET=

# Optional: Postgres connection string for running migrations (db:migrate / db:seed).
# Format: postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres
# (or the Supabase pooler URI). Only needed to apply schema; not used by the app at runtime.
SUPABASE_DB_URL=
